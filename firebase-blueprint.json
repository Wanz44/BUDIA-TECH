{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A gadget or digital device sold by BUDIA TECH",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in local currency" },
        "stock": { "type": "number", "description": "Current stock level" },
        "category": { "type": "string", "description": "Category (e.g., Computers, Cameras)" },
        "imageUrl": { "type": "string", "description": "URL to product image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "category"]
    },
    "Service": {
      "title": "Service",
      "description": "IT or audiovisual service offered by BUDIA TECH",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Service name" },
        "description": { "type": "string", "description": "Service details" },
        "priceRange": { "type": "string", "description": "Estimated price range" },
        "category": { "type": "string", "description": "Category (e.g., Web, Mobile, Audiovisual)" },
        "imageUrl": { "type": "string", "description": "URL to service icon or image" }
      },
      "required": ["name", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for products",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "productIds": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "productIds", "totalAmount", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact form submission or quote request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["contact", "quote"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "type"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of contact submissions"
    }
  }
}
